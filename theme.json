{
  "$schema": "https://schemas.wp.org/trunk/theme.json",
  "version": 3,
  "settings": {
    "appearanceTools": true,
    "useRootPaddingAwareAlignments": true,
    "layout": {
      "contentSize": "var(--wp-content-width)",
      "wideSize": "var(--wp-wide-width)"
    },
    "color": {
      "palette": [
        {
          "slug": "brand",
          "name": "Brand",
          "color": "#d21629"
        },
        {
          "slug": "accent",
          "name": "Accent",
          "color": "#4a4549"
        },
        {
          "slug": "text",
          "name": "Text",
          "color": "#333333"
        },
        {
          "slug": "heading",
          "name": "Heading",
          "color": "#000000"
        },
        {
          "slug": "background",
          "name": "Background",
          "color": "#ffffff"
        },
        {
          "slug": "surface",
          "name": "Surface",
          "color": "#F2F3F3"
        }
      ]
    },
    "spacing": {
      "units": [
        "px",
        "rem",
        "vw",
        "vh",
        "%"
      ],
      "spacingSizes": [
        {
          "slug": "20",
          "name": "XS",
          "size": "0.75rem"
        },
        {
          "slug": "30",
          "name": "S",
          "size": "1rem"
        },
        {
          "slug": "40",
          "name": "M",
          "size": "1.5rem"
        },
        {
          "slug": "50",
          "name": "L",
          "size": "2.25rem"
        },
        {
          "slug": "60",
          "name": "XL",
          "size": "4rem"
        }
      ]
    },
    "typography": {
      "fluid": true,
      "fontFamilies": [
        {
          "slug": "body",
          "name": "Body",
          "fontFamily": "var(--wp-body-font)"
        },
        {
          "slug": "heading",
          "name": "Heading",
          "fontFamily": "var(--wp-heading-font)"
        },
        {
          "slug": "ui",
          "name": "UI",
          "fontFamily": "var(--wp-ui-font)"
        }
      ],
      "fontSizes": [
        {
          "slug": "small",
          "name": "Small",
          "size": "var(--wp-font-size-small)"
        },
        {
          "slug": "medium",
          "name": "Body",
          "size": "var(--wp-body-size)"
        },
        {
          "slug": "large",
          "name": "Large",
          "size": "var(--wp-font-size-medium)"
        },
        {
          "slug": "x-large",
          "name": "H2",
          "size": "var(--wp-h2-font-size)"
        },
        {
          "slug": "xx-large",
          "name": "H1",
          "size": "var(--wp-h1-font-size)"
        }
      ]
    }
  },
  "styles": {
    "color": {
      "background": "var(--wp-background-color)",
      "text": "var(--wp-text-color)"
    },
    "typography": {
      "fontFamily": "var(--wp-body-font)",
      "fontSize": "var(--wp-body-size)"
    },
    "elements": {
      "heading": {
        "color": {
          "text": "var(--wp-heading-color)"
        },
        "typography": {
          "fontFamily": "var(--wp-heading-font)"
        }
      },
      "link": {
        "color": {
          "text": "var(--wp-link-color)"
        }
      },
      "button": {
        "border": {
          "radius": "var(--wp-theme-radius)"
        }
      }
    }
  },
  "templateParts": [
    {
      "area": "header",
      "name": "header",
      "title": "Header"
    },
    {
      "area": "footer",
      "name": "footer",
      "title": "Footer"
    }
  ]
}