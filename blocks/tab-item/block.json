{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "dp-blocks/tab-item",
  "title": "DP Tab Item",
  "category": "design",
  "icon": "excerpt-view",
  "description": "Single tab panel with navigation link and content",
  "parent": ["dp-blocks/tabs"],
  "supports": {
    "html": false,
    "reusable": false
  },
  "attributes": {
    "title": {
      "type": "string",
      "default": "Tab"
    },
    "tabId": {
      "type": "string",
      "default": ""
    },
    "icon": {
      "type": "string",
      "default": ""
    },
    "disabled": {
      "type": "boolean",
      "default": false
    }
  },
  "editorScript": "file:./src/edit.js",
  "editorStyle": "file:./src/editor.css"
}