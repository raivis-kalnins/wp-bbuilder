{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "dp-blocks/accordion-item",
  "title": "DP Accordion Item",
  "category": "design",
  "icon": "excerpt-view",
  "description": "Single accordion panel with header and collapsible content",
  "parent": ["dp-blocks/accordion"],
  "supports": {
    "html": false,
    "reusable": false
  },
  "attributes": {
    "title": {
      "type": "string",
      "default": "Accordion Item"
    },
    "itemId": {
      "type": "string",
      "default": ""
    },
    "initiallyOpen": {
      "type": "boolean",
      "default": false
    },
    "headerTag": {
      "type": "string",
      "default": "h2"
    },
    "headerClass": {
      "type": "string",
      "default": ""
    },
    "buttonClass": {
      "type": "string",
      "default": ""
    }
  },
  "editorScript": "file:./src/edit.js",
  "editorStyle": "file:./src/editor.css"
}