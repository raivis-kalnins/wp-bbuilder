{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "dp-blocks/cards",
  "title": "DP Cards (Bootstrap)",
  "category": "design",
  "icon": "grid-view",
  "description": "Bootstrap card grid with multiple layout options",
  "keywords": ["cards", "grid", "bootstrap", "gallery"],
  "supports": {
    "anchor": true,
    "align": ["wide", "full"],
    "html": false,
    "spacing": {
      "padding": true,
      "margin": true
    }
  },
  "attributes": {
    "columns": {
      "type": "number",
      "default": 3
    },
    "columnsTablet": {
      "type": "number",
      "default": 2
    },
    "columnsMobile": {
      "type": "number",
      "default": 1
    },
    "gutter": {
      "type": "string",
      "default": "g-4"
    },
    "equalHeight": {
      "type": "boolean",
      "default": true
    },
    "cardGroup": {
      "type": "boolean",
      "default": false
    },
    "cardDeck": {
      "type": "boolean",
      "default": false
    }
  },
  "editorScript": "file:./src/edit.js",
  "editorStyle": "file:./src/editor.css",
  "style": "file:./src/style.css",
  "render": "file:./render.php",
  "allowedBlocks": ["dp-blocks/card"]
}